{
  "name": "@philiprehberger/http-status",
  "version": "0.1.2",
  "description": "Typed HTTP status codes, reason phrases, and classification",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "http",
    "status-code",
    "status",
    "reason-phrase",
    "rest",
    "api"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-http-status.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-http-status#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-http-status/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
